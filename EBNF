// ============================================================================
// Rivet Language Specification (Final EBNF Grammar)
// Target: LLVM IR -> ARM Cortex-M0 (Bare-Metal)
// ============================================================================

<program> ::= <declaration_list>

<declaration_list> ::= <declaration> { <declaration> }

<declaration> ::= <variable_declaration> | <function_declaration>

// --- Types & Variables ---
<type_specifier> ::= "int" | "int" "ref" | "void"

<variable_declaration> ::= <type_specifier> <identifier> "=" <expression> ";"
                         | <type_specifier> <identifier> ";"

// --- Functions ---
<function_declaration> ::= <type_specifier> <identifier> "(" <params> ")" <compound_statement>

<params> ::= "void" | <param_list> | <empty>

<param_list> ::= <param> { "," <param> }

<param> ::= <type_specifier> <identifier>

// --- Statements ---
<compound_statement> ::= "{" <statement_list> "}"

<statement_list> ::= { <statement> }

<statement> ::= <variable_declaration>
              | <expression_statement>
              | <compound_statement>
              | <selection_statement>
              | <iteration_statement>
              | <return_statement>

<expression_statement> ::= [ <expression> ] ";"

<selection_statement> ::= "if" "(" <expression> ")" <statement> [ "else" <statement> ]

<iteration_statement> ::= "while" "(" <expression> ")" <statement>

<return_statement> ::= "return" [ <expression> ] ";"

// --- Expressions (Ordered by Precedence) ---

<expression> ::= <assignment_target> "=" <expression> 
               | <logical_or_expression>

<assignment_target> ::= <identifier> 
                      | "deref" <identifier>

<logical_or_expression> ::= <logical_and_expression> { "or" <logical_and_expression> }

<logical_and_expression> ::= <equality_expression> { "and" <equality_expression> }

<equality_expression> ::= <relational_expression> { <equality_operator> <relational_expression> }

<equality_operator> ::= "==" | "!="

<relational_expression> ::= <shift_expression> { <relational_operator> <shift_expression> }

<relational_operator> ::= "<" | "<=" | ">" | ">="

<shift_expression> ::= <additive_expression> { <shift_operator> <additive_expression> }

<shift_operator> ::= "lsft" | "rsft"

<additive_expression> ::= <term> { <additive_operator> <term> }

<additive_operator> ::= "+" | "-"

<term> ::= <unary_expression> { <multiplicative_operator> <unary_expression> }

<multiplicative_operator> ::= "*" | "/" | "%"

<unary_expression> ::= "not" <unary_expression>
                     | "-" <unary_expression>
                     | "address_of" <identifier>
                     | "deref" <identifier>
                     | <factor>

<factor> ::= "(" <expression> ")" 
           | <identifier> 
           | <number> 
           | <function_call>

<function_call> ::= <identifier> "(" <args> ")"

<args> ::= <arg_list> | <empty>

<arg_list> ::= <expression> { "," <expression> }

// --- Lexical Tokens ---
<identifier> ::= <letter> { <letter> | <digit> | "_" }
<number>     ::= <digit> { <digit> }
<letter>     ::= "a".."z" | "A".."Z"
<digit>      ::= "0".."9"
<empty>      ::= 

// --- Comments (Ignored by Lexer) ---
<line_comment> ::= "//" { <any_character_except_newline> } <newline>
<block_comment> ::= "/*" { <any_character> } "*/"